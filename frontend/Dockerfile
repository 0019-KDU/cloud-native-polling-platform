# Build stage
FROM node:18-alpine AS builder
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .

ARG REACT_APP_AUTH_SERVICE_URL
ARG REACT_APP_POLL_SERVICE_URL
ARG REACT_APP_VOTE_SERVICE_URL
ARG REACT_APP_ANALYTICS_SERVICE_URL
ARG REACT_APP_REALTIME_SERVICE_URL

ENV REACT_APP_AUTH_SERVICE_URL=$REACT_APP_AUTH_SERVICE_URL
ENV REACT_APP_POLL_SERVICE_URL=$REACT_APP_POLL_SERVICE_URL
ENV REACT_APP_VOTE_SERVICE_URL=$REACT_APP_VOTE_SERVICE_URL
ENV REACT_APP_ANALYTICS_SERVICE_URL=$REACT_APP_ANALYTICS_SERVICE_URL
ENV REACT_APP_REALTIME_SERVICE_URL=$REACT_APP_REALTIME_SERVICE_URL

RUN npm run build

# Serve stage
FROM nginx:alpine
COPY --from=builder /app/build /usr/share/nginx/html
COPY nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]

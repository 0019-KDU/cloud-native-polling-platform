# ─────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────
POSTGRES_USER=polluser
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=pollingdb

# ─────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password

# ─────────────────────────────────────────────
# JWT (must be at least 32 characters)
# ─────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRATION=86400000

# ─────────────────────────────────────────────
# Frontend API URLs
# For local dev without Docker, point to localhost.
# In Kubernetes/production, leave these EMPTY so the
# frontend uses relative URLs routed through the Gateway.
# ─────────────────────────────────────────────
REACT_APP_AUTH_SERVICE_URL=http://localhost:8081
REACT_APP_POLL_SERVICE_URL=http://localhost:8082
REACT_APP_VOTE_SERVICE_URL=http://localhost:8083
REACT_APP_ANALYTICS_SERVICE_URL=http://localhost:8084
REACT_APP_REALTIME_SERVICE_URL=http://localhost:3001
